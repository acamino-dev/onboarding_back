{
  "name": "onboarding-back",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "sam build",
    "local": "sam local start-api --warm-containers EAGER --host 0.0.0.0 --port 4000 --config-env local --config-file samconfig.toml",
    "deploy:dev": "sam deploy --config-env dev",
    "migrate-db": "tsx scripts/migrate.ts",
    "reset-db": "NODE_ENV=dev tsx scripts/reset-db.ts",
    "seed-db": "DB_SECRET_ID=onboardingCredentialsDev ts-node scripts/seed-integration.ts"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.0",
    "@types/jest": "^29.0.0",
    "@types/node": "^22.19.19",
    "@types/pg": "^8.20.0",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "dotenv": "^17.4.2",
    "eslint": "^10.4.0",
    "jest": "^29.0.0",
    "prettier": "^3.8.3",
    "ts-jest": "^29.0.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1067.0",
    "@aws-sdk/client-secrets-manager": "^3.1054.0",
    "@aws-sdk/lib-dynamodb": "^3.1067.0",
    "bcryptjs": "^3.0.3",
    "pg": "^8.13.0",
    "zod": "^3.24.0"
  }
}
